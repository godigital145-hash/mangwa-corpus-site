---
import Layout from "../../layouts/Layout.astro";
import Header from "../../Componant/Header";
import Footer from "../../Componant/Footer";
import Container from "../../Componant/Container";
import VideoDetail from "../../Componant/VideoDetail";
import { api, mediaUrl } from "../../lib/api";

const { id } = Astro.params;
if (!id) return Astro.redirect("/videos");

let video = null;
try { video = await api.video(id); } catch {}

const seoTitle = video?.title ?? "Vidéo";
const seoDesc = video?.description ?? "Regardez cette vidéo sur Mangwa Corpus.";
const seoImage = video?.thumbnail ? mediaUrl(video.thumbnail) ?? undefined : undefined;

const jsonLd = video ? {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: video.title,
  description: seoDesc,
  thumbnailUrl: seoImage,
  inLanguage: "fr",
  ...(video.published_at ? { uploadDate: video.published_at } : {}),
  ...(video.video_url ? { contentUrl: video.video_url } : {}),
} : undefined;
---

<Layout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  type="video.other"
  jsonLd={jsonLd}
>
  <Header client:load />

  <Container>
    <div class="py-6">
      <nav class="flex items-center gap-2 text-[13px] text-gray-400 mb-6">
        <a href="/videos" class="hover:text-gray-700 transition-colors">Vidéos</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">{video?.title ?? "Lecture"}</span>
      </nav>

      <VideoDetail client:load id={id} />
    </div>
  </Container>

  <Footer client:load />
</Layout>
