---
import Layout from "../layouts/Layout.astro";
import Header from "../Componant/Header";
import Banniere from "../Componant/Banniere";
import SectionCategories from "../Componant/SectionCategories";
import PanneauEdition from "../Componant/PanneauEdition";
import SectionEdition from "../Componant/SectionEdition";
import SectionAudio from "../Componant/SectionAudio";
import SectionLibrairie from "../Componant/SectionLibrairie";
import Footer from "../Componant/Footer";
---

<Layout>
	<Header client:load />
	<Banniere
		client:load
		imageUrl=""
		titre="Plongez au Cœur de l'Information et du Son"
	/>
	<SectionCategories client:load />
	<PanneauEdition
		client:load
		nom="Samuel ETO'O"
		description="Un homme, une histoire, une légende vivante"
		ctaLabel="Obtenir un exemple"
		ctaHref="#"
	/>
	<SectionEdition client:load />
	<SectionAudio client:load />
	<SectionLibrairie client:load />
	<Footer client:load />
</Layout>
