---
import Layout from "../layouts/Layout.astro";
import Header from "../Componant/Header";
import Footer from "../Componant/Footer";
import Container from "../Componant/Container";
import CheckoutPage from "../Componant/CheckoutPage";

const type = Astro.url.searchParams.get("type") as "magazine" | "audio" | "album" | null;
const id   = Astro.url.searchParams.get("id");

if (!type || !id || (type !== "magazine" && type !== "audio" && type !== "album")) {
  return Astro.redirect("/");
}
---

<Layout title="Paiement" description="Finalisez votre achat sur Mangwa Corpus.">
  <Header client:load />

  <Container>
    <CheckoutPage client:load type={type} id={id} />
  </Container>

  <Footer client:load />
</Layout>
