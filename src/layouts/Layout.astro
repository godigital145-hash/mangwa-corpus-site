---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import StickyPlayer from "../Componant/StickyPlayer";
import logo from "../assets/logo.png";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: object;
}

const {
  title,
  description = "Découvrez les musiques, magazines et e-books africains sur Mangwa Corpus. Une médiathèque culturelle riche en contenus audio, visuels et littéraires.",
  image,
  type = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

const siteTitle = title
  ? `${title} — Mangwa Corpus`
  : "Mangwa Corpus – Musiques, Magazines & E-Books africains";
const canonical = Astro.url.href;
const origin = Astro.url.origin;
const ogImage = image ?? `${origin}/og-default.png`;

const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Mangwa Corpus",
  url: origin,
  logo: `${origin}/favicon.svg`,
  description,
  inLanguage: "fr",
};
const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang='fr'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <link rel='icon' type='image/svg+xml' href={logo.src} />
    <link rel='icon' href={logo.src} />
    <link rel='apple-touch-icon' href={logo.src} />
    <meta name='generator' content={Astro.generator} />

    <!-- Primary -->
    <title>{siteTitle}</title>
    <meta name='description' content={description} />
    <link rel='canonical' href={canonical} />
    {noindex && <meta name='robots' content='noindex,nofollow' />}

    <!-- Open Graph -->
    <meta property='og:type' content={type} />
    <meta property='og:title' content={siteTitle} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonical} />
    <meta property='og:image' content={ogImage} />
    <meta property='og:image:alt' content={siteTitle} />
    <meta property='og:locale' content='fr_FR' />
    <meta property='og:site_name' content='Mangwa Corpus' />

    <!-- Twitter Card -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={siteTitle} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImage} />

    <!-- JSON-LD -->
    <script
      type='application/ld+json'
      set:html={JSON.stringify(structuredData)}
    />

    <ClientRouter />
  </head>
  <body>
    <div
      id='page-loader'
      style='display:flex'
      class='fixed inset-0 z-9999 bg-white flex-col items-center justify-center'>
      <p
        class='text-[#00bcd4] font-bold text-xs uppercase tracking-widest mb-5'>
        Mangwa Corpus
      </p>
      <div
        class='w-6 h-6 border-2 border-gray-200 border-t-[#00bcd4] rounded-full animate-spin'>
      </div>
    </div>

    <script>
      function getLoader() {
        return document.getElementById("page-loader") as HTMLElement | null;
      }
      function hide() {
        const el = getLoader();
        if (!el) return;
        el.style.transition = "opacity 0.35s ease";
        el.style.opacity = "0";
        el.style.pointerEvents = "none";
        setTimeout(() => {
          const e = getLoader();
          if (e) e.style.display = "none";
        }, 350);
      }
      function show() {
        const el = getLoader();
        if (!el) return;
        el.style.display = "flex";
        el.style.opacity = "1";
        el.style.pointerEvents = "auto";
        el.style.transition = "";
      }
      window.addEventListener("load", () => setTimeout(hide, 100), {
        once: true,
      });
      document.addEventListener("astro:before-preparation", show);
      document.addEventListener("astro:page-load", () => setTimeout(hide, 150));
      setTimeout(hide, 5000);
    </script>

    <slot />
    <div transition:persist='sticky-player'>
      <StickyPlayer client:load />
    </div>
    <script
      type='text/javascript'
      src='https://fr.monetbil.com/widget/v2/monetbil.min.js'></script>
  </body>
</html>
