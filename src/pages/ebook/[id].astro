---
import Layout from "../../layouts/Layout.astro";
import Header from "../../Componant/Header";
import Footer from "../../Componant/Footer";
import Container from "../../Componant/Container";
import EbookDetailViewer from "../../Componant/EbookDetailViewer";
import { api, mediaUrl } from "../../lib/api";

const { id } = Astro.params;
if (!id) return Astro.redirect("/ebook");

let ebook = null;
try { ebook = await api.ebook(id); } catch {}

const seoTitle = ebook?.title ?? "E-Book";
const seoDesc = ebook?.description
  ?? "Lisez cet e-book africain en exclusivité sur Mangwa Corpus.";
const seoImage = ebook?.cover ? mediaUrl(ebook.cover) ?? undefined : undefined;

const jsonLd = ebook ? {
  "@context": "https://schema.org",
  "@type": "Book",
  name: ebook.title,
  description: seoDesc,
  image: seoImage,
  inLanguage: "fr",
  publisher: { "@type": "Organization", name: "Mangwa Corpus" },
  ...(ebook.published_at ? { datePublished: ebook.published_at } : {}),
} : undefined;
---

<Layout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  type="article"
  jsonLd={jsonLd}
>
  <Header client:load />

  <Container>
    <nav class="flex items-center gap-2 text-[13px] text-gray-400 mt-6 mb-2">
      <a href="/ebook" class="hover:text-gray-700 transition-colors">E-Book</a>
      <span>/</span>
      <span class="text-gray-700 font-medium">{ebook?.title ?? "Détail"}</span>
    </nav>

    <EbookDetailViewer client:load id={id} />
  </Container>

  <Footer client:load />
</Layout>
