---
import Layout from "../../layouts/Layout.astro";
import Header from "../../Componant/Header";
import Footer from "../../Componant/Footer";
import Container from "../../Componant/Container";
import AudioItemPlayer from "../../Componant/AudioItemPlayer";
import { api, mediaUrl } from "../../lib/api";

const { id } = Astro.params;
if (!id) return Astro.redirect("/podcasts");

let podcast = null;
try { podcast = await api.podcast(id); } catch {}

const seoTitle = podcast
  ? `${podcast.title}${podcast.artist ? ` — ${podcast.artist}` : ""}`
  : "Podcast";
const seoDesc = podcast?.description
  ?? "Écoutez ce podcast africain sur Mangwa Corpus.";
const seoImage = podcast?.cover ? mediaUrl(podcast.cover) ?? undefined : undefined;

const jsonLd = podcast ? {
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  name: podcast.title,
  description: seoDesc,
  image: seoImage,
  inLanguage: "fr",
  ...(podcast.published_at ? { datePublished: podcast.published_at } : {}),
} : undefined;
---

<Layout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  type="music.song"
  jsonLd={jsonLd}
>
  <Header client:load />

  <Container>
    <div class="py-6">
      <nav class="flex items-center gap-2 text-[13px] text-gray-400 mb-6">
        <a href="/podcasts" class="hover:text-gray-700 transition-colors">Podcasts</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">{podcast?.title ?? "Lecture"}</span>
      </nav>

      <AudioItemPlayer client:load id={id} />
    </div>
  </Container>

  <Footer client:load />
</Layout>
